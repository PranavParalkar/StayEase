@model StayEase.DTO.Room
@{ ViewData["Title"] = Model.RoomID.Contains("0000") ? "Add Room" : "Edit Room"; }

<div class="page-header">
    <h1>@ViewData["Title"]</h1>
    <a href="/Room" class="btn btn-secondary">← Back</a>
</div>

@if (ViewBag.Error != null) { <div class="alert alert-error">@ViewBag.Error</div> }

<div class="form-card">
    <form method="post">
        <input type="hidden" name="RoomID" value="@Model.RoomID" />
        <div class="form-group">
            <label>Room ID</label>
            <input type="text" class="form-control" value="@Model.RoomID" disabled />
        </div>
        <div class="form-group">
            <label>Room Name</label>
            <input type="text" name="RoomName" class="form-control" value="@Model.RoomName" required />
        </div>
        <div class="form-group">
            <label>Type</label>
            <select name="RoomType" class="form-control">
                <option value="0" selected="@(Model.RoomType==0)">VIP</option>
                <option value="1" selected="@(Model.RoomType==1)">Standard</option>
            </select>
        </div>
        <div class="form-group">
            <label>Detail</label>
            <select name="RoomDetail" class="form-control">
                <option value="0" selected="@(Model.RoomDetail==0)">Single</option>
                <option value="1" selected="@(Model.RoomDetail==1)">Double</option>
                <option value="2" selected="@(Model.RoomDetail==2)">Family</option>
            </select>
        </div>
        <div class="form-group">
            <label>Price (₹)</label>
            <input type="number" name="Price" class="form-control" value="@Model.Price" required />
        </div>
        <div class="form-group">
            <label>Status</label>
            <select name="Status" class="form-control">
                <option value="0" selected="@(Model.Status==0)">Available</option>
                <option value="1" selected="@(Model.Status==1)">Occupied</option>
                <option value="2" selected="@(Model.Status==2)">Not Cleaned</option>
                <option value="3" selected="@(Model.Status==3)">Under Repair</option>
            </select>
        </div>
        <div class="form-group">
            <label>Condition</label>
            <select name="Condition" class="form-control">
                <option value="0" selected="@(Model.Condition==0)">New</option>
                <option value="1" selected="@(Model.Condition==1)">Old</option>
            </select>
        </div>
        <button type="submit" class="btn btn-success">💾 Save</button>
    </form>
</div>
