@{ ViewData["Title"] = "Add Service";
    var services = (List<StayEase.DTO.Service>)ViewBag.Services;
}

<div class="page-header"><h1>🍽 Add Service to Booking</h1><a href="/Booking/Details/@ViewBag.BookingID" class="btn btn-secondary">← Back</a></div>

<div class="form-card">
    <form method="post">
        <input type="hidden" name="bookingId" value="@ViewBag.BookingID" />
        <div class="form-group"><label>Service</label>
            <select name="serviceId" class="form-control" required>
                @foreach (var s in services) { <option value="@s.ServiceID">@s.ServiceName — ₹@s.Price</option> }
            </select>
        </div>
        <div class="form-group"><label>Quantity</label><input type="number" name="quantity" class="form-control" value="1" min="1" required /></div>
        <button type="submit" class="btn btn-success">➕ Add Service</button>
    </form>
</div>
