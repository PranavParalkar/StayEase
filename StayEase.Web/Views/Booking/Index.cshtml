@model List<StayEase.DTO.Booking>
@{ ViewData["Title"] = "Bookings"; }

<div class="page-header">
    <h1>Booking Management</h1>
    <a href="/Booking/Create" class="btn btn-success"><i data-lucide="plus" style="width:16px;height:16px;"></i> New Booking</a>
</div>

<div class="table-wrapper">
    <table class="data-table">
        <thead><tr><th>Booking ID</th><th>Customer</th><th>Employee</th><th>Date</th><th>Deposit</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        @if (!Model.Any()) { <tr><td colspan="7"><div class="empty-state"><p>No bookings yet</p></div></td></tr> }
        @foreach (var b in Model)
        {
            <tr>
                <td><strong>@b.BookingID</strong></td><td>@b.CustomerID</td>
                <td style="color:var(--text-secondary);">@b.EmployeeID</td>
                <td>@b.BookingDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td style="font-weight:600;">₹@b.Deposit.ToString("N0")</td>
                <td><span class="badge @(b.ProcessStatus==0?"badge-pending":"badge-processed")">@b.StatusDisplay</span></td>
                <td><div class="action-row">
                    <a href="/Booking/Details/@b.BookingID" class="btn btn-primary btn-sm"><i data-lucide="eye" style="width:14px;height:14px;"></i> Details</a>
                    <a href="/Booking/AddService/@b.BookingID" class="btn btn-warning btn-sm"><i data-lucide="concierge-bell" style="width:14px;height:14px;"></i></a>
                    <form method="post" asp-action="Delete" style="display:inline;"><input type="hidden" name="id" value="@b.BookingID" /><button class="btn btn-danger btn-sm" onclick="return confirm('Delete?')"><i data-lucide="trash-2" style="width:14px;height:14px;"></i></button></form>
                </div></td>
            </tr>
        }
        </tbody>
    </table>
</div>
<script>lucide.createIcons();</script>
