@model StayEase.DTO.Booking
@{ ViewData["Title"] = "Booking Details";
    var rooms = (List<StayEase.DTO.BookingRoom>)ViewBag.Rooms;
    var services = (List<StayEase.DTO.BookingService>)ViewBag.Services;
}

<div class="page-header">
    <h1>Booking @Model.BookingID</h1>
    <a href="/Booking" class="btn btn-secondary"><i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Back to Bookings</a>
</div>

<div class="detail-grid">
    <div class="stat-card"><div class="stat-label">Customer</div><div class="stat-value" style="font-size:1.15rem;">@Model.CustomerID</div></div>
    <div class="stat-card"><div class="stat-label">Status</div><div style="margin-top:8px;"><span class="badge @(Model.ProcessStatus==0?"badge-pending":"badge-processed")" style="font-size:0.85rem;">@Model.StatusDisplay</span></div></div>
    <div class="stat-card"><div class="stat-label">Booking Date</div><div class="stat-value" style="font-size:1rem;">@Model.BookingDate.ToString("yyyy-MM-dd HH:mm")</div></div>
    <div class="stat-card"><div class="stat-label">Deposit</div><div class="stat-value" style="font-size:1.15rem;">₹@Model.Deposit.ToString("N0")</div></div>
</div>

<div class="section-title"><span class="accent-bar"></span> Booked Rooms</div>
<div class="table-wrapper" style="margin-bottom:28px;">
    <table class="data-table">
        <thead><tr><th>Room</th><th>Check-In</th><th>Check-Out</th><th>Price</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        @foreach (var r in rooms)
        {
            <tr>
                <td><strong>@r.RoomID</strong></td>
                <td>@r.CheckInDate.ToString("yyyy-MM-dd")</td>
                <td>@(r.CheckOutDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                <td style="font-weight:600;">₹@r.RentalPrice.ToString("N0")</td>
                <td><span class="badge @(r.Status==0?"badge-pending":r.Status==1?"badge-available":"badge-processed")">@r.StatusDisplay</span></td>
                <td>
                    @if (r.Status == 0) {
                        <form method="post" asp-action="CheckIn" style="display:inline;">
                            <input type="hidden" name="bookingId" value="@Model.BookingID" /><input type="hidden" name="roomId" value="@r.RoomID" /><input type="hidden" name="checkInDate" value="@r.CheckInDate.ToString("yyyy-MM-ddTHH:mm:ss")" />
                            <button class="btn btn-success btn-sm"><i data-lucide="log-in" style="width:14px;height:14px;"></i> Check-In</button>
                        </form>
                    } else if (r.Status == 1) {
                        <form method="post" asp-action="CheckOut" style="display:inline;">
                            <input type="hidden" name="bookingId" value="@Model.BookingID" /><input type="hidden" name="roomId" value="@r.RoomID" /><input type="hidden" name="checkInDate" value="@r.CheckInDate.ToString("yyyy-MM-ddTHH:mm:ss")" />
                            <button class="btn btn-purple btn-sm"><i data-lucide="log-out" style="width:14px;height:14px;"></i> Check-Out</button>
                        </form>
                    } else { <span style="color:var(--success);font-weight:500;">Completed</span> }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="section-title"><span class="accent-bar"></span> Services Used</div>
<div class="table-wrapper">
    <table class="data-table">
        <thead><tr><th>Service</th><th>Date</th><th>Qty</th><th>Price</th></tr></thead>
        <tbody>
        @foreach (var s in services) { <tr><td>@s.ServiceID</td><td>@s.UsageDate.ToString("yyyy-MM-dd")</td><td>@s.Quantity</td><td style="font-weight:600;">₹@s.Price.ToString("N0")</td></tr> }
        @if (!services.Any()) { <tr><td colspan="4"><div class="empty-state"><p>No services added yet</p></div></td></tr> }
        </tbody>
    </table>
</div>
<script>lucide.createIcons();</script>
