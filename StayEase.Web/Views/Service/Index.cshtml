@model List<StayEase.DTO.Service>
@{ ViewData["Title"] = "Services"; }

<div class="page-header">
    <h1>🍽 Service Management</h1>
    <a href="/Service/Create" class="btn btn-success">➕ Add Service</a>
</div>

<div class="toolbar">
    <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;">
        <input type="text" name="search" class="form-control" placeholder="Search services..." value="@ViewBag.Search" />
        <select name="category" class="form-control" onchange="this.form.submit()">
            <option value="All">All Categories</option>
            <option value="Food & Beverage" selected="@(ViewBag.Category=="Food & Beverage")">Food & Beverage</option>
            <option value="Beauty Care" selected="@(ViewBag.Category=="Beauty Care")">Beauty Care</option>
            <option value="Entertainment" selected="@(ViewBag.Category=="Entertainment")">Entertainment</option>
            <option value="Party Services" selected="@(ViewBag.Category=="Party Services")">Party Services</option>
        </select>
        <button type="submit" class="btn btn-primary btn-sm">🔍</button>
    </form>
</div>

<table class="data-table">
    <thead><tr><th>ID</th><th>Name</th><th>Category</th><th>Price</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var s in Model)
    {
        <tr>
            <td>@s.ServiceID</td><td><strong>@s.ServiceName</strong></td><td>@s.ServiceType</td><td>₹@s.Price.ToString("N0")</td>
            <td>
                <a href="/Service/Edit/@s.ServiceID" class="btn btn-primary btn-sm">✏️</a>
                <form method="post" asp-action="Delete" style="display:inline;"><input type="hidden" name="id" value="@s.ServiceID" /><button class="btn btn-danger btn-sm" onclick="return confirm('Delete?')">🗑️</button></form>
            </td>
        </tr>
    }
    </tbody>
</table>
