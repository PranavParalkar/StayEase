@model StayEase.DTO.Service
@{ ViewData["Title"] = string.IsNullOrEmpty(Model.ServiceName) ? "Add Service" : "Edit Service"; }

<div class="page-header"><h1>@ViewData["Title"]</h1><a href="/Service" class="btn btn-secondary">← Back</a></div>

<div class="form-card">
    <form method="post">
        <input type="hidden" name="ServiceID" value="@Model.ServiceID" />
        <div class="form-group"><label>Service ID</label><input class="form-control" value="@Model.ServiceID" disabled /></div>
        <div class="form-group"><label>Service Name</label><input type="text" name="ServiceName" class="form-control" value="@Model.ServiceName" required /></div>
        <div class="form-group"><label>Category</label>
            <select name="ServiceType" class="form-control">
                <option value="Food & Beverage" selected="@(Model.ServiceType=="Food & Beverage")">Food & Beverage</option>
                <option value="Beauty Care" selected="@(Model.ServiceType=="Beauty Care")">Beauty Care</option>
                <option value="Entertainment" selected="@(Model.ServiceType=="Entertainment")">Entertainment</option>
                <option value="Party Services" selected="@(Model.ServiceType=="Party Services")">Party Services</option>
            </select>
        </div>
        <div class="form-group"><label>Price (₹)</label><input type="number" name="Price" class="form-control" value="@Model.Price" required /></div>
        <button type="submit" class="btn btn-success">💾 Save</button>
    </form>
</div>
