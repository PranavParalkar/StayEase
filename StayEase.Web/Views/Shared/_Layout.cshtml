@{
    var permissions = User.FindFirst("Permissions")?.Value ?? "";
    var permSet = new HashSet<string>(permissions.Split(',', StringSplitOptions.RemoveEmptyEntries));
    bool HasPerm(string fid) => permSet.Contains(fid);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — StayEase</title>
    <meta name="description" content="StayEase Hotel Management System — Web Application" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="app-wrapper">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <h2>🏨 StayEase</h2>
                <small>Hotel Management</small>
            </div>
            <ul class="sidebar-nav">
                <li><a href="/" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"><span class="icon">📊</span> Dashboard</a></li>
                @if (HasPerm("F001")) { <li><a href="/Room" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Room" ? "active" : "")"><span class="icon">🛏</span> Rooms</a></li> }
                @if (HasPerm("F002")) { <li><a href="/Service" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Service" ? "active" : "")"><span class="icon">🍽</span> Services</a></li> }
                @if (HasPerm("F003")) { <li><a href="/Customer" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")"><span class="icon">👤</span> Customers</a></li> }
                @if (HasPerm("F004")) { <li><a href="/Employee" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" ? "active" : "")"><span class="icon">👨‍💼</span> Employees</a></li> }
                @if (HasPerm("F006")) { <li><a href="/Booking" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Booking" ? "active" : "")"><span class="icon">📋</span> Bookings</a></li> }
                @if (HasPerm("F007")) { <li><a href="/Invoice" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")"><span class="icon">💰</span> Invoices</a></li> }
                @if (HasPerm("F008")) { <li><a href="/Statistics" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Statistics" ? "active" : "")"><span class="icon">📈</span> Statistics</a></li> }
            </ul>
            <div class="sidebar-user">
                <div class="user-name">@User.Identity.Name</div>
                <div class="user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-logout btn-sm">🚪 Logout</button>
                </form>
            </div>
        </aside>
        <main class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">✅ @TempData["Success"]</div>
            }
            @RenderBody()
        </main>
    </div>
}
else
{
    @RenderBody()
}

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
