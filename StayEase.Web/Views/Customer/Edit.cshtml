@model StayEase.DTO.Customer
@{ ViewData["Title"] = string.IsNullOrEmpty(Model.FullName) ? "Add Customer" : "Edit Customer"; }

<div class="page-header"><h1>@ViewData["Title"]</h1><a href="/Customer" class="btn btn-secondary">← Back</a></div>

<div class="form-card">
    <form method="post">
        <input type="hidden" name="CustomerID" value="@Model.CustomerID" />
        <div class="form-group"><label>Customer ID</label><input class="form-control" value="@Model.CustomerID" disabled /></div>
        <div class="form-group"><label>Full Name</label><input type="text" name="FullName" class="form-control" value="@Model.FullName" required /></div>
        <div class="form-group"><label>ID Card</label><input type="text" name="IDCard" class="form-control" value="@Model.IDCard" /></div>
        <div class="form-group"><label>Gender</label><select name="Gender" class="form-control"><option value="0" selected="@(Model.Gender==0)">Male</option><option value="1" selected="@(Model.Gender==1)">Female</option></select></div>
        <div class="form-group"><label>Phone</label><input type="text" name="Phone" class="form-control" value="@Model.Phone" /></div>
        <div class="form-group"><label>Address</label><input type="text" name="Address" class="form-control" value="@Model.Address" /></div>
        <div class="form-group"><label>Nationality</label><input type="text" name="Nationality" class="form-control" value="@Model.Nationality" /></div>
        <div class="form-group"><label>Date of Birth</label><input type="date" name="DateOfBirth" class="form-control" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" /></div>
        <button type="submit" class="btn btn-success">💾 Save</button>
    </form>
</div>
