{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "StayEase Web",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-web",
            "program": "${workspaceFolder}/StayEase.Web/bin/Debug/net10.0/StayEase.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/StayEase.Web",
            "stopAtEntry": false,
            "console": "internalConsole",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}
